{
  "name": "zig-bump",
  "version": "0.1.3",
  "scripts": {
    "release": "zig build -Doptimize=ReleaseFast --global-cache-dir .zig-cache/global && ./zig-out/bin/bump prompt",
    "release:patch": "zig build -Doptimize=ReleaseFast --global-cache-dir .zig-cache/global && ./zig-out/bin/bump patch --yes",
    "release:minor": "zig build -Doptimize=ReleaseFast --global-cache-dir .zig-cache/global && ./zig-out/bin/bump minor --yes",
    "release:major": "zig build -Doptimize=ReleaseFast --global-cache-dir .zig-cache/global && ./zig-out/bin/bump major --yes"
  }
}
